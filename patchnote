{
  "name": "PatchNote",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "description": "Version number like 1.0.0"
    },
    "title": {
      "type": "string"
    },
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "feature",
              "fix",
              "balance",
              "content"
            ]
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "release_date": {
      "type": "string",
      "format": "date"
 
